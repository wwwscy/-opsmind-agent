# MiniMax API Key（必填，从 MiniMax 开放平台获取：https://platform.minimaxi.com/）
MINIMAX_API_KEY=sk-your-key-here

# MiniMax 模型（调试用 M2.1，生产用 M2.7）
MINIMAX_CHAT_MODEL=MiniMax-M2.1

# MiniMax Embedding 模型
MINIMAX_EMBEDDING_MODEL=embo01

# MiniMax API 地址（OpenAI 兼容端点）
MINIMAX_BASE_URL=https://api.minimax.chat/v2

# MySQL（生产环境填写，开发用 H2 内嵌数据库无需配置）
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/opsmind
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=root

# Milvus（生产环境填写，开发用内存向量库无需配置）
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
